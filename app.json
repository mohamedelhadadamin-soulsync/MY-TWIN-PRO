{
  "expo": {
    "name": "MyTwin",
    "slug": "my-twin",
    "scheme": "mytwin",
    "version": "16.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0014"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.soulsync.mytwin",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "يحتاج التطبيق للميكروفون للمحادثات الصوتية.",
        "NSCameraUsageDescription": "للسماح لك بإرسال الصور إلى توأمك",
        "NSPhotoLibraryUsageDescription": "للسماح لك بمشاركة الصور مع توأمك",
        "NSLocationWhenInUseUsageDescription": "يستخدم الموقع لتحسين تجربة التوأم.",
        "ITSAppUsesNonExemptEncryption": false,
        "GADApplicationIdentifier": "ca-app-pub-3940256099942544~1458002511"
      }
    },
    "android": {
      "package": "com.soulsync.mytwin",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0014"
      },
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "INTERNET",
        "VIBRATE",
        "ACCESS_FINE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "POST_NOTIFICATIONS",
        "com.android.vending.BILLING",
        "com.google.android.gms.permission.AD_ID"
      ]
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#7C3AED"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "react-native-google-mobile-ads",
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": false,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24
          },
          "ios": {
            "newArchEnabled": false,
            "useFrameworks": "static"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#7C3AED"
        }
      ],
      [
        "onesignal-expo-plugin",
        { "mode": "development" }
      ]
    ],
    "extra": {
      "router": { "origin": false },
      "eas": { "projectId": "b3a5e167-a18c-4ed5-b929-5e84f8356bce" },
      "cli": { "appVersionSource": "local" }
    },
    "runtimeVersion": { "policy": "sdkVersion" },
    "updates": { "url": "https://u.expo.dev/b5e2baa3-6015-40a5-9f31-115298d3b0c9" },
    "owner": "soulsync.9",
    "sdkVersion": "52.0.0",
    "jsEngine": "hermes"
  }
}
